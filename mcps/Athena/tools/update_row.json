{
  "name": "update_row",
  "description": "Update rows matching a condition. Blocked when read_only mode is enabled.",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "table": {
        "type": "string",
        "description": "Table name (optionally schema-qualified)"
      },
      "set": {
        "type": "object",
        "propertyNames": {
          "type": "string"
        },
        "additionalProperties": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "number"
            },
            {
              "type": "boolean"
            },
            {
              "type": "null"
            }
          ]
        },
        "description": "Column-value pairs to set"
      },
      "where_column": {
        "type": "string",
        "description": "Column to match in WHERE clause"
      },
      "where_value": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          },
          {
            "type": "boolean"
          }
        ],
        "description": "Value to match (converted to string)"
      },
      "schema": {
        "description": "Optional schema when table name is not schema-qualified",
        "type": "string"
      }
    },
    "required": [
      "table",
      "set",
      "where_column",
      "where_value"
    ]
  }
}