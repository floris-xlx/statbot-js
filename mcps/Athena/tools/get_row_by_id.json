{
  "name": "get_row_by_id",
  "description": "Fetch rows by primary key column value. Simplifies the common fetch-by-id use case.",
  "inputSchema": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "table": {
        "type": "string",
        "description": "Table name (optionally schema-qualified)"
      },
      "id": {
        "anyOf": [
          {
            "type": "string"
          },
          {
            "type": "number"
          }
        ],
        "description": "Primary key value (typically id)"
      },
      "id_column": {
        "description": "Primary key column name (defaults to 'id')",
        "type": "string"
      },
      "schema": {
        "description": "Optional schema when table name is not schema-qualified",
        "type": "string"
      },
      "limit": {
        "description": "Maximum rows to return (defaults to 100)",
        "type": "integer",
        "exclusiveMinimum": 0,
        "maximum": 9007199254740991
      }
    },
    "required": [
      "table",
      "id"
    ]
  }
}