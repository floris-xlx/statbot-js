{
  "name": "statbot-js",
  "version": "0.1.0",
  "description": "Type-safe JavaScript SDK for the Statbot API.",
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "openapi/openapi.json",
    "openapi/openapi.yaml",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "clean": "rimraf dist src/generated/openapi-types.ts openapi/openapi.json openapi/openapi.yaml",
    "openapi:generate": "node ./scripts/generate-openapi.mjs",
    "sdk:generate": "openapi-typescript ./openapi/openapi.json -o ./src/generated/openapi-types.ts",
    "generate": "npm run openapi:generate && npm run sdk:generate",
    "build": "npm run generate && tsup",
    "typecheck": "npm run generate && tsc --noEmit",
    "test": "vitest run",
    "prepack": "npm run build"
  },
  "keywords": [
    "statbot",
    "discord",
    "sdk",
    "openapi",
    "typescript"
  ],
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^25.9.3",
    "openapi-typescript": "^7.13.0",
    "rimraf": "^6.1.3",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.9",
    "yaml": "^2.9.0"
  },
  "dependencies": {
    "openapi-fetch": "^0.17.0"
  }
}
